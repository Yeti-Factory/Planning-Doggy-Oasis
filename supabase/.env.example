# Edge Function secrets. Configure with `supabase secrets set --env-file supabase/.env`.
# Keep the real supabase/.env file outside Git.
BACKUP_INVOKE_SECRET=GENERATE_A_LONG_RANDOM_VALUE

# Optional external copy. Omit all four values to use Supabase Storage only.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
ONEDRIVE_BACKUP_LINK=
